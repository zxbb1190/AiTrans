{
  "meta": {
    "updated_at": "2026-03-09",
    "l3_sync_notes": [
      {
        "id": "SYNC-20260309-structure-definition-section",
        "note": "Promote 'structure' into a dedicated core-standard section, clarifying that structure is the primary abstract organization unit, that it can be either module-local minimal units or higher-layer composed units, and that it must be distinguished from capabilities, boundaries, modules, and implementation details."
      },
      {
        "id": "SYNC-20260309-base-not-global-leaf",
        "note": "Clarify that B* is the minimal structure unit within the current module boundary rather than a mandatory global leaf in the whole framework graph; higher-layer bases may be composed from lower-layer modules while only the lowest expanded layer must remain self-contained."
      },
      {
        "id": "SYNC-20260309-framework-lint-standard",
        "note": "Split framework semantic core from framework markdown/lint governance: keep semantic rules in specs/框架设计核心标准.md, move expression/author-entry/lint contract into specs/框架文档Lint标准.md, and explicitly link the new L1 lint standard into the tree plus active frontend L2 standard."
      },
      {
        "id": "SYNC-20260309-framework-template-entry",
        "note": "Promote plain @framework standard-template generation to a hard repository authoring constraint, and keep the active framework/tooling chain aligned with a non-removable direct entry plus regression coverage."
      },
      {
        "id": "SYNC-20260309-product-spec-comment-style",
        "note": "Require product_spec.toml and implementation_config.toml to use detailed Chinese comments as the primary human-and-AI discussion surface, and sync the active frontend/knowledge_base/backend framework modules to this authoring rule."
      },
      {
        "id": "SYNC-20260309-framework-product-impl-layering",
        "note": "Promote the repository-wide AI coding layering model: framework as shared structural language, product spec as implementation-independent product truth, implementation config as technical refinement, with one-way truth flow into code and evidence."
      },
      {
        "id": "SYNC-20260305-runtime-env-l0",
        "note": "Add framework/runtime_env/L0-M0-运行环境识别模块.md for framework directive schema trial."
      },
      {
        "id": "SYNC-20260305-frontend-foundation-flow",
        "note": "Refactor frontend L2-L6 docs to enforce component-first composition path: atom components -> base templates/open-source wrappers -> page routing -> login-centric business flows."
      },
      {
        "id": "SYNC-20260305-l0-abstract-bases-normalization",
        "note": "Normalize specs and framework docs (frontend/curtain/runtime_env/shelf) to enforce L0-first modeling and abstract Minimal Viable Bases with boundary-driven instance expansion."
      },
      {
        "id": "SYNC-20260305-bases-structure-first",
        "note": "Rewrite all framework B* definitions as finite structural units (structure-first), avoiding function-first phrasing."
      },
      {
        "id": "SYNC-20260306-frontend-multi-path-graph",
        "note": "Frontend multi-path graph is inferred from framework base definitions (B*) and rule participation (参与基), without extra graph directives."
      },
      {
        "id": "SYNC-20260306-inline-upstream-b-format",
        "note": "Unify B* syntax to inline upstream module refs (B*: Lx.My[...]. 来源: ...), remove legacy '上游模块' clause, and enforce with FW023."
      },
      {
        "id": "SYNC-20260306-structure-first-hardening",
        "note": "Remove legacy framework scaffold tooling, harden inline module-growth validation (FW024/FW025/FW026), and align frontend/framework wording plus plugin snippets to the structure-first model."
      },
      {
        "id": "SYNC-20260306-core-standard-bases-clarification",
        "note": "Clarify in core standard that Minimal Viable Base is a structure unit rather than an ability unit, that each layer may define new bases while references must remain adjacent, and that B-line format must inline module refs directly."
      },
      {
        "id": "SYNC-20260306-code-standards-folder",
        "note": "Move Python implementation quality rules out of core framework standard into specs/code/ so code conventions can expand by language without mixing into framework design core."
      },
      {
        "id": "SYNC-20260307-knowledge-base-ai-coding",
        "note": "Refactor the AI-coding sample into a structure-first stack: generic frontend structures, knowledge-base domain structures, backend knowledge contracts, and a project-instantiated knowledge_base_runtime bound to the L2 framework standards."
      },
      {
        "id": "SYNC-20260307-frontend-primitive-sink",
        "note": "Sink the frontend framework to concrete L0 primitive atoms (input/trigger, text/carrier, list/hierarchy, marker/feedback), move token/runtime support to later L0 modules, and realign knowledge_base L0 modules to reference specific frontend primitives instead of a coarse component family."
      },
      {
        "id": "SYNC-20260307-frontend-atomic-frameworks",
        "note": "Further split frontend L0 into standalone atomic frameworks for button, input field, textarea, file picker, text block, panel viewport, list hierarchy, and marker feedback; then realign frontend assembly and knowledge_base domain atoms to grow from these finer-grained primitive structures."
      },
      {
        "id": "SYNC-20260307-frontend-common-structure-layer",
        "note": "Insert a deeper frontend common-structure L0 (slot shell, state channel, host binding), float concrete component atoms to L1, keep the frontend standard at L2, and realign knowledge_base domain atoms to reference frontend L1 component atoms while preserving the structure-first dependency chain."
      },
      {
        "id": "SYNC-20260308-frontend-extreme-compression",
        "note": "Rework the frontend framework into a cleaner compressed chain: L0 carrier/state/visual atoms, L1 trigger-text-display-navigation-feedback atomic families, L2 standard contract, and L3 page-runtime orchestration; then realign knowledge_base and Shelf AI navigation fixtures to the new module graph."
      }
    ]
  },
