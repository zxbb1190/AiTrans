{
  "meta": {
    "updated_at": "2026-03-06",
    "l3_sync_notes": [
      {
        "id": "SYNC-20260305-runtime-env-l0",
        "note": "Add framework/runtime_env/L0-M0-运行环境识别模块.md for framework directive schema trial."
      },
      {
        "id": "SYNC-20260305-frontend-foundation-flow",
        "note": "Refactor frontend L2-L6 docs to enforce component-first composition path: atom components -> base templates/open-source wrappers -> page routing -> login-centric business flows."
      },
      {
        "id": "SYNC-20260305-l0-abstract-bases-normalization",
        "note": "Normalize specs and framework docs (frontend/curtain/runtime_env/shelf) to enforce L0-first modeling and abstract Minimal Viable Bases with boundary-driven instance expansion."
      },
      {
        "id": "SYNC-20260305-bases-structure-first",
        "note": "Rewrite all framework B* definitions as finite structural units (structure-first), avoiding function-first phrasing."
      },
      {
        "id": "SYNC-20260306-frontend-multi-path-graph",
        "note": "Frontend multi-path graph is inferred from framework base definitions (B*) and rule participation (参与基), without extra graph directives."
      },
      {
        "id": "SYNC-20260306-inline-upstream-b-format",
        "note": "Unify B* syntax to inline upstream module refs (B*: Lx.My[...]. 来源: ...), remove legacy '上游模块' clause, and enforce with FW023."
      },
      {
        "id": "SYNC-20260306-structure-first-hardening",
        "note": "Remove legacy framework scaffold tooling, harden inline module-growth validation (FW024/FW025/FW026), and align frontend/framework wording plus plugin snippets to the structure-first model."
      },
      {
        "id": "SYNC-20260306-core-standard-bases-clarification",
        "note": "Clarify in core standard that Minimal Viable Base is a structure unit rather than an ability unit, that each layer may define new bases while references must remain adjacent, and that B-line format must inline module refs directly."
      },
      {
        "id": "SYNC-20260306-code-standards-folder",
        "note": "Move Python implementation quality rules out of core framework standard into specs/code/ so code conventions can expand by language without mixing into framework design core."
      }
    ]
  },
