{
  "name": "shelf-ai",
  "displayName": "Shelf AI",
  "description": "Shelf AI: canonical-first navigation for the Framework -> Config -> Code -> Evidence chain.",
  "version": "0.1.8",
  "publisher": "rdshr",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/xueyu888/shelf.git"
  },
  "bugs": {
    "url": "https://github.com/xueyu888/shelf/issues"
  },
  "homepage": "https://github.com/xueyu888/shelf/tree/main/tools/vscode/shelf-ai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE.txt",
    "README.md",
    "extension.js",
    "tree_runtime_models.js",
    "tree_webview_bridge.js",
    "guarding.js",
    "evidence_tree.js",
    "framework_completion.js",
    "framework_navigation.js",
    "config_navigation.js",
    "validation_runtime.js",
    "intent_gate.js",
    "local_settings.js",
    "media/**",
    "snippets/**",
    "package.nls.json",
    "package.nls.zh-cn.json"
  ],
  "categories": [
    "Linters",
    "Other"
  ],
  "scripts": {
    "build:webview": "node scripts/build_tree_webview.mjs",
    "check:webview-types": "tsc --pretty false --noEmit -p webview/tree/tsconfig.json",
    "test": "node test_guarding.js && node test_framework_navigation.js && node test_config_navigation.js && node test_evidence_tree.js && node test_validation_runtime.js && node test_intent_gate.js && node test_local_settings.js && node test_snippets.js && node test_tree_runtime_models.js && node test_tree_webview_bridge.js",
    "vscode:prepublish": "npm run build:webview"
  },
  "devDependencies": {
    "@types/d3-selection": "^3.0.11",
    "@types/d3-zoom": "^3.0.8",
    "@types/dagre": "^0.7.52",
    "d3-selection": "^3.0.0",
    "d3-zoom": "^3.0.0",
    "dagre": "^0.8.5",
    "esbuild": "^0.25.9",
    "typescript": "^5.9.2"
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:shelf.sidebarHome",
    "onCommand:shelf.insertFrameworkModuleTemplate",
    "onCommand:shelf.installGitHooks",
    "onCommand:shelf.startGovernedTask",
    "onCommand:shelf.showGovernedTaskSession",
    "onCommand:shelf.clearGovernedTaskSession",
    "onCommand:shelf.validateNow",
    "onCommand:shelf.codegenPreflight",
    "onCommand:shelf.publishFrameworkDraft",
    "onCommand:shelf.openFrameworkTree",
    "onCommand:shelf.refreshFrameworkTree",
    "onCommand:shelf.openEvidenceTree",
    "onCommand:shelf.refreshEvidenceTree"
  ],
  "main": "./extension.js",
  "contributes": {
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "shelf.insertFrameworkModuleTemplate",
        "title": "Shelf: Insert Framework Module Template"
      },
      {
        "command": "shelf.validateNow",
        "title": "Shelf: Validate Canonical Now"
      },
      {
        "command": "shelf.codegenPreflight",
        "title": "Shelf: Run Codegen Preflight"
      },
      {
        "command": "shelf.publishFrameworkDraft",
        "title": "Shelf: Publish Current Framework Draft"
      },
      {
        "command": "shelf.installGitHooks",
        "title": "Shelf: Install Git Hooks"
      },
      {
        "command": "shelf.startGovernedTask",
        "title": "Shelf: Start Governed Task"
      },
      {
        "command": "shelf.showGovernedTaskSession",
        "title": "Shelf: Show Governed Task Session"
      },
      {
        "command": "shelf.clearGovernedTaskSession",
        "title": "Shelf: Clear Governed Task Session"
      },
      {
        "command": "shelf.showIssues",
        "title": "Shelf: Show Validation Issues"
      },
      {
        "command": "shelf.openFrameworkTree",
        "title": "Shelf: Open Framework Tree"
      },
      {
        "command": "shelf.refreshFrameworkTree",
        "title": "Shelf: Refresh Framework Tree"
      },
      {
        "command": "shelf.openEvidenceTree",
        "title": "Shelf: Open Evidence Tree"
      },
      {
        "command": "shelf.refreshEvidenceTree",
        "title": "Shelf: Refresh Evidence Tree"
      }
    ],
    "icons": {
      "shelf-logo": {
        "description": "Shelf AI Activity Bar icon",
        "default": {
          "fontPath": "media/shelf-ai-icons.woff2",
          "fontCharacter": "\\ea01"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shelfSidebar",
          "title": "Shelf",
          "icon": "$(shelf-logo)"
        }
      ]
    },
    "views": {
      "shelfSidebar": [
        {
          "id": "shelf.sidebarHome",
          "name": "Shelf",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "shelf.startGovernedTask",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@1"
        },
        {
          "command": "shelf.openFrameworkTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@2"
        },
        {
          "command": "shelf.refreshFrameworkTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@3"
        },
        {
          "command": "shelf.openEvidenceTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@4"
        },
        {
          "command": "shelf.refreshEvidenceTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@5"
        },
        {
          "command": "shelf.validateNow",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@6"
        },
        {
          "command": "shelf.codegenPreflight",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@7"
        },
        {
          "command": "shelf.publishFrameworkDraft",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@8"
        },
        {
          "command": "shelf.installGitHooks",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@9"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "shelf.enableOnSave": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.enableOnSave.description%"
        },
        "shelf.validationTriggerMode": {
          "type": "string",
          "enum": [
            "manual",
            "save",
            "all"
          ],
          "default": "all",
          "description": "%configuration.shelf.validationTriggerMode.description%"
        },
        "shelf.notifyOnAutoFail": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.notifyOnAutoFail.description%"
        },
        "shelf.guardMode": {
          "type": "string",
          "enum": [
            "normal",
            "strict"
          ],
          "default": "normal",
          "description": "%configuration.shelf.guardMode.description%"
        },
        "shelf.autoMaterialize": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.autoMaterialize.description%"
        },
        "shelf.runMypyOnPythonChanges": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.runMypyOnPythonChanges.description%"
        },
        "shelf.protectGeneratedFiles": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.protectGeneratedFiles.description%"
        },
        "shelf.promptInstallGitHooks": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.promptInstallGitHooks.description%"
        },
        "shelf.intentGateEnabled": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.intentGateEnabled.description%"
        },
        "shelf.intentGateEnforcementMode": {
          "type": "string",
          "enum": [
            "warn",
            "block"
          ],
          "default": "block",
          "description": "%configuration.shelf.intentGateEnforcementMode.description%"
        },
        "shelf.intentGateRequireMappingEcho": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.intentGateRequireMappingEcho.description%"
        },
        "shelf.intentGateRunChangeValidationBeforeGrant": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.intentGateRunChangeValidationBeforeGrant.description%"
        },
        "shelf.intentGateAutoOpenOutput": {
          "type": "boolean",
          "default": true,
          "description": "%configuration.shelf.intentGateAutoOpenOutput.description%"
        },
        "shelf.intentGateMinimumScore": {
          "type": "integer",
          "default": 4,
          "minimum": 1,
          "maximum": 20,
          "description": "%configuration.shelf.intentGateMinimumScore.description%"
        },
        "shelf.intentGateMaxMatches": {
          "type": "integer",
          "default": 8,
          "minimum": 1,
          "maximum": 20,
          "description": "%configuration.shelf.intentGateMaxMatches.description%"
        },
        "shelf.intentGateSessionTtlMinutes": {
          "type": "integer",
          "default": 120,
          "minimum": 1,
          "maximum": 1440,
          "description": "%configuration.shelf.intentGateSessionTtlMinutes.description%"
        },
        "shelf.intentGateGuardedPathPrefixes": {
          "type": "array",
          "default": [
            "framework/",
            "framework_drafts/",
            "projects/",
            "src/project_runtime/",
            "scripts/",
            "tools/vscode/shelf-ai/"
          ],
          "items": {
            "type": "string"
          },
          "description": "%configuration.shelf.intentGateGuardedPathPrefixes.description%"
        },
        "shelf.intentGateIgnoredPathPrefixes": {
          "type": "array",
          "default": [
            ".git/",
            ".github/",
            ".venv/",
            "node_modules/",
            "dist/",
            "build/",
            "out/",
            ".pytest_cache/",
            ".mypy_cache/",
            "__pycache__/"
          ],
          "items": {
            "type": "string"
          },
          "description": "%configuration.shelf.intentGateIgnoredPathPrefixes.description%"
        },
        "shelf.intentGateTemporaryBypasses": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "enum": [
              "*",
              "save_guard",
              "grant_pre_validation",
              "mapping_echo",
              "one_to_one_check"
            ]
          },
          "description": "%configuration.shelf.intentGateTemporaryBypasses.description%"
        },
        "shelf.changeValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_canonical.py --check-changes",
          "description": "%configuration.shelf.changeValidationCommand.description%"
        },
        "shelf.fullValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_canonical.py",
          "description": "%configuration.shelf.fullValidationCommand.description%"
        },
        "shelf.materializeCommand": {
          "type": "string",
          "default": "uv run python scripts/materialize_project.py",
          "description": "%configuration.shelf.materializeCommand.description%"
        },
        "shelf.typeCheckCommand": {
          "type": "string",
          "default": "uv run mypy",
          "description": "%configuration.shelf.typeCheckCommand.description%"
        },
        "shelf.frameworkTreeNodeHorizontalGap": {
          "type": "integer",
          "default": 8,
          "minimum": 0,
          "maximum": 40,
          "description": "%configuration.shelf.frameworkTreeNodeHorizontalGap.description%"
        },
        "shelf.frameworkTreeLevelVerticalGap": {
          "type": "integer",
          "default": 80,
          "minimum": 48,
          "maximum": 180,
          "description": "%configuration.shelf.frameworkTreeLevelVerticalGap.description%"
        },
        "shelf.treeZoomMinScale": {
          "type": "number",
          "default": 0.68,
          "minimum": 0.2,
          "maximum": 3,
          "description": "%configuration.shelf.treeZoomMinScale.description%"
        },
        "shelf.treeZoomMaxScale": {
          "type": "number",
          "default": 1.55,
          "minimum": 0.2,
          "maximum": 5,
          "description": "%configuration.shelf.treeZoomMaxScale.description%"
        },
        "shelf.treeWheelSensitivity": {
          "type": "number",
          "default": 1,
          "minimum": 0.25,
          "maximum": 3,
          "description": "%configuration.shelf.treeWheelSensitivity.description%"
        },
        "shelf.treeInspectorWidth": {
          "type": "integer",
          "default": 338,
          "minimum": 240,
          "maximum": 520,
          "description": "%configuration.shelf.treeInspectorWidth.description%"
        },
        "shelf.treeInspectorRailWidth": {
          "type": "integer",
          "default": 42,
          "minimum": 32,
          "maximum": 72,
          "description": "%configuration.shelf.treeInspectorRailWidth.description%"
        },
        "shelf.validationCommandTimeoutMs": {
          "type": "integer",
          "default": 120000,
          "minimum": 1000,
          "maximum": 1800000,
          "description": "%configuration.shelf.validationCommandTimeoutMs.description%"
        },
        "shelf.generatedEventSuppressionMs": {
          "type": "integer",
          "default": 2500,
          "minimum": 0,
          "maximum": 30000,
          "description": "%configuration.shelf.generatedEventSuppressionMs.description%"
        },
        "shelf.manualValidationRestartThresholdMs": {
          "type": "integer",
          "default": 15000,
          "minimum": 1000,
          "maximum": 300000,
          "description": "%configuration.shelf.manualValidationRestartThresholdMs.description%"
        },
        "shelf.validationDebounceMs": {
          "type": "integer",
          "default": 250,
          "minimum": 0,
          "maximum": 5000,
          "description": "%configuration.shelf.validationDebounceMs.description%"
        }
      }
    }
  }
}
