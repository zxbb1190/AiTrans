{
  "name": "shelf-ai",
  "displayName": "Shelf AI",
  "description": "Shelf AI: structure-first framework tree workspace and strict mapping guard.",
  "version": "0.0.37",
  "publisher": "rdshr",
  "license": "SEE LICENSE IN LICENSE.txt",
  "repository": {
    "type": "git",
    "url": "https://github.com/xueyu888/shelf.git"
  },
  "bugs": {
    "url": "https://github.com/xueyu888/shelf/issues"
  },
  "homepage": "https://github.com/xueyu888/shelf/tree/main/tools/vscode/shelf-ai",
  "engines": {
    "vscode": "^1.85.0"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE.txt",
    "README.md",
    "extension.js",
    "framework_completion.js",
    "framework_navigation.js",
    "media/**",
    "snippets/**"
  ],
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onView:shelf.sidebarHome",
    "onCommand:shelf.insertFrameworkModuleTemplate",
    "onCommand:shelf.validateNow",
    "onCommand:shelf.openFrameworkTree",
    "onCommand:shelf.refreshFrameworkTree"
  ],
  "main": "./extension.js",
  "contributes": {
    "snippets": [
      {
        "language": "markdown",
        "path": "./snippets/markdown.code-snippets"
      }
    ],
    "commands": [
      {
        "command": "shelf.insertFrameworkModuleTemplate",
        "title": "Shelf: Insert Framework Module Template"
      },
      {
        "command": "shelf.validateNow",
        "title": "Shelf: Validate Mapping Now"
      },
      {
        "command": "shelf.showIssues",
        "title": "Shelf: Show Mapping Issues"
      },
      {
        "command": "shelf.openFrameworkTree",
        "title": "Shelf: Open Framework Tree"
      },
      {
        "command": "shelf.refreshFrameworkTree",
        "title": "Shelf: Refresh Framework Tree"
      }
    ],
    "icons": {
      "shelf-logo": {
        "description": "Shelf AI Activity Bar icon",
        "default": {
          "fontPath": "media/shelf-ai-icons.woff2",
          "fontCharacter": "\\ea01"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "shelfSidebar",
          "title": "Shelf",
          "icon": "$(shelf-logo)"
        }
      ]
    },
    "views": {
      "shelfSidebar": [
        {
          "id": "shelf.sidebarHome",
          "name": "Shelf",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "shelf.openFrameworkTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@1"
        },
        {
          "command": "shelf.refreshFrameworkTree",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@2"
        },
        {
          "command": "shelf.validateNow",
          "when": "view == shelf.sidebarHome",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Shelf",
      "properties": {
        "shelf.enableOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Run strict mapping validation when a relevant file is saved."
        },
        "shelf.notifyOnAutoFail": {
          "type": "boolean",
          "default": true,
          "description": "Show notification when auto validation detects mapping issues."
        },
        "shelf.changeValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_strict_mapping.py --check-changes --json",
          "description": "Command used for save-triggered validation."
        },
        "shelf.fullValidationCommand": {
          "type": "string",
          "default": "uv run python scripts/validate_strict_mapping.py --json",
          "description": "Command used for manual full validation."
        },
        "shelf.frameworkTreeHtmlPath": {
          "type": "string",
          "default": "docs/hierarchy/shelf_framework_tree.html",
          "description": "Workspace-relative path of generated framework tree HTML."
        },
        "shelf.frameworkTreeGenerateCommand": {
          "type": "string",
          "default": "uv run python scripts/generate_framework_tree_hierarchy.py --source framework --framework-dir framework --output-json docs/hierarchy/shelf_framework_tree.json --output-html docs/hierarchy/shelf_framework_tree.html",
          "description": "Command used by 'Refresh Framework Tree'."
        }
      }
    }
  }
}
