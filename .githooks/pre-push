#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

if ! command -v uv >/dev/null 2>&1; then
  echo "[pre-push] blocked: uv is required but was not found in PATH." >&2
  exit 1
fi

echo "[pre-push] strict mapping validation..."
echo "[pre-push] static type check..."
uv run mypy
echo "[pre-push] materialize project artifacts..."
uv run python scripts/materialize_project.py
uv run python scripts/validate_strict_mapping.py
uv run python scripts/validate_strict_mapping.py --check-changes
echo "[pre-push] strict mapping checks passed."
